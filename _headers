# Cloudflare Pages headers. https://developers.cloudflare.com/pages/configuration/headers/

# Saved token sets change often — never serve a stale copy.
/_shared/tokens/*
  Cache-Control: no-cache

# Shared CSS/JS: revalidate so design-system edits propagate quickly.
/_shared/*
  Cache-Control: public, max-age=0, must-revalidate

# Revalidate everything (HTML + the unversioned app.js/styles.css the tools
# reference). ETags make this cheap (304s), and it prevents a stale cached
# app.js from desyncing with fresh HTML after a deploy. Don't use a long
# max-age here unless assets are content-hashed.
/*
  Cache-Control: public, max-age=0, must-revalidate
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
